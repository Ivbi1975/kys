modules = ["nodejs-24", "javascript", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: local-test"

[[workflows.workflow]]
name = "artifacts/api-server: local-test"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && env -u DB_HOST -u DB_POSTGRESQL_PASS -u DB_NAME APP_PASSWORD=Muratabi12 PORT=3001 HOST=0.0.0.0 DB_DISABLE_WARMUP=1 node keepalive.mjs"
waitForPort = 3001

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DB_POOL_MAX = "25"
VITE_API_BASE_URL = "https://api.kys.gelecekvadisi.org"

[userenv.production]
ALLOWED_ORIGINS = "https://kys.gelecekvadisi.org,https://liste.gelecekvadisi.org"

[[ports]]
localPort = 8080
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18604
externalPort = 3000
