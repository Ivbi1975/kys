modules = ["nodejs-24", "javascript", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DB_POOL_MAX = "25"
VITE_API_BASE_URL = "https://api.kys.gelecekvadisi.org"

[userenv.production]
ALLOWED_ORIGINS = "https://kys.gelecekvadisi.org,https://liste.gelecekvadisi.org"

[[ports]]
localPort = 8080
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18604
externalPort = 3000
