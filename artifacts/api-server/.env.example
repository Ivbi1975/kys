# API authentication key for server-to-server clients that call protected API routes directly.
API_KEY=change-me-api-key

# Short password users type on the application login screen.
APP_PASSWORD=change-me-login-password

# Long secret used only to sign browser session tokens after APP_PASSWORD login.
SESSION_SECRET=change-me-session-secret

# Admin-only key for restricted operations (e.g. backup import, integrity repair)
ADMIN_KEY=change-me-admin-key

# VYS (external system) read-only API key — used exclusively on /api/vys/* routes
VYS_API_KEY=change-me-vys-api-key

# Database connection URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kys

# Comma-separated list of allowed CORS origins (e.g. https://kys.example.com)
ALLOWED_ORIGINS=

# Set to "production" for production mode
NODE_ENV=development

# ──────────────────────────────────────────────
# Rate Limiting
# All values represent the maximum number of requests allowed per 60-second window.
# ──────────────────────────────────────────────

# Global rate limit applied to every incoming request (default: 200)
GLOBAL_RATE_LIMIT=200

# Rate limit for tracking routes (/api/tracking, /api/v1/tracking) (default: 30)
TRACKING_RATE_LIMIT=30

# Rate limit for AI classification routes (/api/ai-notes/classify*) (default: 5)
AI_CLASSIFY_RATE_LIMIT=5

# Rate limit for bulk import route (/api/backup/import) (default: 3)
BULK_IMPORT_RATE_LIMIT=3
